# Backend - Desarrollo Local
# Copia este archivo como .env.local y completa con tus datos reales (NO subas a Git)

PORT=5000
NODE_ENV=development

# MongoDB - Local
MONGO_URI=mongodb://localhost:27017/ecommerce

# MongoDB - Atlas (descomentar para usar en la nube)
# MONGO_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/ecommerce?retryWrites=true&w=majority

# JWT
JWT_SECRET=tu_clave_jwt_super_segura_aqui
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=tu_clave_refresh_segura_aqui
REFRESH_TOKEN_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_STORAGE_LIMIT_MB=500

# Mercado Pago
MP_ACCESS_TOKEN=tu_mp_access_token
MP_PUBLIC_KEY=tu_mp_public_key
MP_WEBHOOK_SECRET=tu_mp_webhook_secret

# Email (Gmail con App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password_de_gmail

# WhatsApp
WHATSAPP_NUMBER=tu_numero_whatsapp

# Admin
ADMIN_EMAIL=admin@tienda.com
EMAIL_FROM=noreply@tienda.com

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# AI Engine (opcional)
AI_ENGINE_MODE=balanced
GROQ_API_KEY=tu_groq_key
MISTRAL_API_KEY=tu_mistral_key
OPENAI_API_KEY=tu_openai_key (opcional)

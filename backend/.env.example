PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/ecommerce

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_change_this
REFRESH_TOKEN_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_STORAGE_LIMIT_MB=500

# Mercado Pago
MP_ACCESS_TOKEN=your_mp_access_token
MP_PUBLIC_KEY=your_mp_public_key
MP_WEBHOOK_SECRET=your_mp_webhook_secret

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com

# WhatsApp
WHATSAPP_NUMBER=5491100000000

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Admin email
ADMIN_EMAIL=admin@tienda.com

# AI ENGINE CONFIGURATION
AI_ENGINE_MODE=balanced
GROQ_API_KEY=your_groq_api_key
MISTRAL_API_KEY=your_mistral_api_key
OPENAI_API_KEY=your_openai_api_key (optional)
GEMINI_API_KEY=
HUGGINGFACE_API_KEY=
WHATSAPP_NUMBER=5491100000000

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Admin email
ADMIN_EMAIL=admin@tienda.com

# ─────────────────────────────────────────────────────────────────────────────
# AI ENGINE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# AI Mode: 'cheap' (no AI) | 'balanced' (default) | 'smart' (high quality)
AI_ENGINE_MODE=balanced

# PRIMARY PROVIDER: Groq (Free, ultra-fast inference)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# FALLBACK PROVIDER #1: Mistral (Free, 2M tokens/month)
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key

# OPTIONAL PAID PROVIDER: Claude via OpenAI (Upgrade for better quality)
# Get key: https://platform.openai.com/api-keys
# Models: gpt-4o-mini (recommended), gpt-4o (best quality)
OPENAI_API_KEY=your_openai_api_key

# DEPRECATED (use Groq instead): Gemini (quota-limited free tier)
GEMINI_API_KEY=

# BACKUP (unreliable): HuggingFace
HUGGINGFACE_API_KEY=

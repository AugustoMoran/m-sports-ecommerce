# ─── AI Engine ───────────────────────────────────────────────────────────────

# Required: Google Gemini (FREE - get key at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: HuggingFace token (increases free rate limits significantly)
# Get at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Optional: OpenAI (paid, for scaling beyond free tier)
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Engine Behaviour ────────────────────────────────────────────────────────

# Mode: cheap | balanced | smart  (default: balanced)
AI_ENGINE_MODE=balanced

# Primary provider: gemini | huggingface | openai  (default: gemini)
AI_PROVIDER=gemini

# Fallback provider (used if primary fails, requires AI_FALLBACK to be set)
AI_FALLBACK=huggingface

# Max AI requests per minute (prevents quota exhaustion)
AI_RPM=15

# Enable debug logging for the engine
AI_ENGINE_DEBUG=false

# ─── Existing project vars (already in your .env) ────────────────────────────
# MONGO_URI=...
# JWT_SECRET=...
# FRONTEND_URL=...
